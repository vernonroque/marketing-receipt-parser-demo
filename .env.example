# ─────────────────────────────────────────────────────────────────
# Environment Variables — Receipt Parser Demo
# ─────────────────────────────────────────────────────────────────
# Copy this file to .env for local development.
# In production, add these in Netlify Dashboard → Site Settings → Environment Variables
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────

# Your RapidAPI key (found in RapidAPI dashboard → Apps → your app)
RAPIDAPI_KEY=your_rapidapi_key_here

# The RapidAPI host for your receipt parser (found on the API's endpoint page)
# Example: receipt-parser3.p.rapidapi.com
RAPIDAPI_HOST=your_rapidapi_host_here

# The full RapidAPI endpoint URL
# Example: https://receipt-parser3.p.rapidapi.com/parse
RAPIDAPI_ENDPOINT=https://your_rapidapi_endpoint_here

# Google reCAPTCHA v3 SECRET key (from console.cloud.google.com)
# The SITE key goes in frontend/index.html and frontend/js/app.js
# The SECRET key goes here (server-side only)
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key_here
